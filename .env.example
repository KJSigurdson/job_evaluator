# Copy to .env and fill in real values. Never commit .env.
ANTHROPIC_API_KEY=sk-ant-...
NOTION_TOKEN=secret_...
NOTION_DB_ID=...                    # 32-char Notion database ID
GOOGLE_SERVICE_ACCOUNT_JSON='{...}' # full JSON blob, or path to a local file
IAP_SHEET_ID=...                    # Google Sheet ID from the URL
IAP_SHEET_TAB=...                   # exact tab name as it appears in the sheet
ALGOLIA_APP_ID=...                  # from 80k Hours network tab (X-Algolia-Application-Id)
ALGOLIA_API_KEY=...                 # from 80k Hours network tab (X-Algolia-API-Key)
ALGOLIA_INDEX_80K=...               # from 80k Hours network tab (index name in request URL)
TIER1_MODEL=claude-haiku-4-5-20251001  # cheap model for rubric scoring (7 dimensions)
TIER2_MODEL=claude-sonnet-4-6          # capable model for org summary + CV guidance
RECENCY_DAYS=14                        # drop postings older than N days (sources without a post date are exempt)
